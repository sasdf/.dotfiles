#!/bin/bash

files=()
IS_COMMITING=0
GITDIR="$(git rev-parse --git-dir)"
EDITMSG=""

commands=(
  "set-option global git_backend git"
)

pinned=( "*git-diff*" )

kakquote() { printf "%s" "$*" | sed "s/'/''/g; 1s/^/'/; \$s/\$/'/"; }

if [[ "${1:-}" == "--editor" ]]; then
  shift
  if [[ "${1:-}" == */COMMIT_EDITMSG ]]; then
    EDITMSG="$1"
    IS_COMMITING=1
    files+=( "$@" )
    shift $#
  else
    echo "Run as normal editor" >&2
    exec kak "$@"
    exit 0
  fi
fi

if [[ $# -ge 1 && "$1" == */* && -f "$1" ]]; then
  exec kak "$@"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ "$IS_COMMITING" -eq "1" || $# -eq 0 ]]; then
  if git diff-index --quiet HEAD --; then
    # No staged or dirty files, likely reword
    refs='HEAD^'
  else
    refs='HEAD'
  fi
elif [[ $# -eq 1 ]]; then
  refs="$1"
  shift
else
  echo "Usage: $0 [commit-msg] [refs]" >&2
  exit 1
fi

mapfile -t diff_files < <(git diff "$refs" --name-only)
files+=( "${diff_files[@]}" )

# Include git logs when not in a commit operation
if [[ "$IS_COMMITING" -eq "0" ]]; then
  if [[ "$refs" != *".."* ]]; then
    log_refs="${refs}.."
  else
    log_refs="$refs"
  fi
  git log -p "$log_refs" > "$GITDIR/CHANGELOG"

  if [[ -s "$GITDIR/CHANGELOG" ]]; then
    files+=( "$GITDIR/CHANGELOG" )
    pinned+=( "*git-log*" )
    commands+=("
      buffer-last
      set buffer filetype git-log
      rename-buffer -scratch *git-log*
    ")
  fi
fi

pinned_args=""
for p in "${pinned[@]}"; do
  pinned_args="$pinned_args $(kakquote "$p")"
done

commands+=("
  set-option global git_revset $(kakquote "$refs")
  git-diff
  genai-set-context true
  arrange-buffers ${pinned_args}
")

if [[ "$IS_COMMITING" -eq "1" ]]; then
  commands+=("
    edit $(kakquote "$EDITMSG")
    arrange-buffers %val{buffile}
  ")
fi

commands+=("
  buffer-first
")

commands="${commands[@]}"

# Ignore SIGINT to prevent accidental termination during editing
# when invoked as a git editor (e.g., git kak)
trap '' SIGINT

kak -e "${commands}" "${files[@]}"
