#!/bin/bash

files=()
EDITOR_MODE=0
MAIN_FILE=""

commands=(
  "set-option global git_backend jj"
)

pinned=( "*git-diff*" )

kakquote() { printf "%s" "$*" | sed "s/'/''/g; 1s/^/'/; \$s/\$/'/"; }

function run_kak () {
  trap '' SIGINT
  set -m # Enable job control
  kak "$@"
  exit 0
}

if [[ "${1:-}" == "--editor" ]]; then
  shift
  if [[ "${1:-}" == *.jjdescription ]]; then
    MAIN_FILE="$1"
    EDITOR_MODE=1
    files+=( "$@" )
    shift $#
  else
    echo "Run as normal editor" >&2
    run_kak "$@"
  fi
fi

if [[ $# -ge 1 && "$1" == */* && -f "$1" ]]; then
  run_kak "$@"
fi

ROOT="$(jj root)"
cd "$ROOT"

if [[ "$EDITOR_MODE" -eq "1" ]]; then
    args=( -r @ )
    revset=( @ )
elif [[ $# -eq 0 ]]; then
  if [ "$(jj log -r @ -T empty --no-graph --color never)" == "true" ]; then
    args=( -r @- )
    revset=( @- )
  else
    args=( -r @ )
    revset=( @ )
  fi
elif [[ $# -eq 1 ]]; then
  args=( -r "$1")
  revset=( "$(kakquote "$1")" )
  shift
elif [[ $# -eq 2 ]]; then
  args=( --from "$1" --to "$2" )
  revset=( "$(kakquote "$1")" "$(kakquote "$2")" )
  shift 2
else
  echo "Usage: $0 [commit-msg] [revset]|[from to]" >&2
  exit 1
fi

mapfile -t diff_files < <(jj diff "${args[@]}" --name-only)
files+=( "${diff_files[@]}" )

pinned_args=""
for p in "${pinned[@]}"; do
  pinned_args="$pinned_args $(kakquote "$p")"
done

commands+=("
  set-option global git_revset ${revset[@]}
  git-diff
  genai-set-context true
  arrange-buffers ${pinned_args}
")

if [[ "$EDITOR_MODE" -eq "1" ]]; then
  commands+=("
    edit $(kakquote "$MAIN_FILE")
    arrange-buffers %val{buffile}
  ")
fi

commands+=("
  buffer-first
")

commands="${commands[@]}"

run_kak -e "${commands}" "${files[@]}"
